// Prisma schema placeholder. We'll hook it up after you confirm DB credentials.

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tour {
  id          Int      @id @default(autoincrement())
  destination String
  title       String
  price       Int
  startDate   DateTime
  endDate     DateTime
  transport   String
  image       String
  description String?  @db.Text
  photos      Json?
  i18n        Json?
  sortOrder   Int      @default(0)
  source      String   @default("manual")
  externalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]

  @@index([source])
  @@index([source, externalId])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  login        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Lead {
  id               Int      @id @default(autoincrement())
  email            String
  destination      String?
  tourId           Int?
  marketingConsent Boolean  @default(false)
  gdprConsent      Boolean  @default(false)
  source           String?
  createdAt        DateTime @default(now())
  tour             Tour?    @relation(fields: [tourId], references: [id], onDelete: SetNull)

  @@index([marketingConsent])
  @@index([tourId])
}

model EmailCampaign {
  id             Int      @id @default(autoincrement())
  subject        String
  preheader      String?
  fromEmail      String?
  html           String
  segment        String
  recipientCount Int      @default(0)
  sentAt         DateTime?
  createdAt      DateTime @default(now())
}

model ProviderTour {
  id            Int      @id @default(autoincrement())
  externalId    String
  source        String
  regionKey     String
  destination   String
  title         String
  price         Int
  originalPrice Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  transport     String
  image         String   @db.Text
  description   String?  @db.Text
  photos        Json?
  url           String   @db.Text
  stars         String   @default("")
  board         String   @default("")
  nights        Int?
  adults        Int?
  children      Int?
  roomType      String?
  currency      String?
  offersCount   Int?
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([source, externalId])
  @@index([source, regionKey])
  @@index([price])
  @@index([startDate])
  @@index([source, regionKey, price])
}

model ProviderSync {
  id           Int      @id @default(autoincrement())
  providerId   String
  regionKey    String
  status       String   @default("idle")
  lastSyncAt   DateTime?
  itemCount    Int      @default(0)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerId, regionKey])
}
