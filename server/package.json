{
  "name": "skytravel-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "npx prisma migrate deploy && node dist/index.js",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "alexandria:refresh": "tsx scripts/refresh-alexandria.ts",
    "alexandria:import": "tsx scripts/refresh-alexandria.ts --import",
    "orextravel:refresh": "tsx scripts/refresh-orextravel.ts",
    "orextravel:import": "tsx scripts/refresh-orextravel.ts --import"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "fast-xml-parser": "^5.5.11",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.17.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^8.57.0",
    "prisma": "^5.18.0",
    "tsx": "^4.15.6",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "tar": "7.5.11",
    "@mapbox/node-pre-gyp": {
      "tar": "7.5.11"
    }
  }
}
